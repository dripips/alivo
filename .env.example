# Database
DATABASE_URL="postgresql://alivo:alivo@localhost:5432/alivo?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=15m

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# VK MAX Bot
MAX_BOT_TOKEN=your-max-bot-token

# AI Provider (openai-compatible)
AI_API_KEY=your-openai-or-anthropic-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5-nano

# App
APP_PORT=3000
APP_URL=http://localhost:3000
DEFAULT_LOCALE=ru

# Escalation timings (minutes)
CHECKIN_REMINDER_DELAY=30
CHECKIN_SECOND_REMINDER_DELAY=60
CHECKIN_ALERT_CONTACTS_DELAY=120
CHECKIN_SOS_DELAY=240

# Medication reminder (minutes)
MEDICATION_REMINDER_DELAY=40
MEDICATION_ALERT_CONTACTS_DELAY=90

# Stripe (SaaS billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email notifications)
RESEND_API_KEY=
RESEND_FROM=Alivo <noreply@alivo.cc>

# Domain (production)
DOMAIN=alivo.cc
